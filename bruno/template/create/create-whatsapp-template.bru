meta {
  name: create-whatsapp-template
  type: http
  seq: 2
}

post {
  url: {{url}}/template
  body: json
  auth: none
}

headers {
  app-id: {{app-id}}
}

body:json {
  {
  "transport": "{{transport-id-twilio}}",
  "name":"Test message Rahat",
  "body":"hello {{name}}, app is being tested by Rahat",
  "type":"TEXT",
  "variables": {
    "name": "John"
    }
  }
}

tests {
  var data = res.getBody().data;
  
  if(data){
    bru.setVar("template-id-whatsapp", data.cuid);
  }
}
