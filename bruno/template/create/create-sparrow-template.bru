meta {
  name: create-sparrow-template
  type: http
  seq: 1
}

post {
  url: {{url}}/template
  body: json
  auth: none
}

headers {
  app-id: {{app-id}}
}

body:json {
  {
  "transport": "{{transport-id-sparrow}}",
  "name":"Demo test",
  "body":"Test for Devs",
  "type":"TEXT"
  }
}

tests {
  var data = res.getBody().data;
  
  if(data){
    bru.setVar("template-id-sparrow", data.cuid);
  }
}
