vars {
  url: https://connect.rumsan.net/api/v1
  dev-email: {{process.env.DEV_EMAIL}}
  dev-phone: {{process.env.DEV_PHONE}}
  slack-url: {{process.env.SLACK_URL}}
  slack-email: {{process.env.SLACK_EMAIL}}
  smtp-host: smtp.gmail.com
  smtp-port: 587
  smtp-username: {{process.env.SMTP_USERNAME}}
  smtp-password: {{process.env.SMTP_PASSWORD}}
  prabhu-sms-token: {{process.env.PRABHU_TOKEN}}
  transport-id-voice: {{process.env.TRANSPORT_ID_VOICE}}
}
