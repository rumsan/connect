generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransportType {
  SMTP
  VOICE
  API
  SES
  ECHO
}

enum CreditUnitType {
  MESSAGE
  SEGMENT
  API_CALL
  SECOND
  MINUTE
}

enum SessionStatus {
  NEW
  PENDING
  COMPLETED
  FAILED
}

enum TriggerType {
  IMMEDIATE
  SCHEDULED
  MANUAL
}

enum BroadcastStatus {
  SCHEDULED
  PENDING
  SUCCESS
  FAIL
}

enum ValidationContent {
  URL
  TEXT
}

enum ValidationAddress {
  ANY
  EMAIL
  PHONE
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum TemplateType {
  TEXT
  MEDIA
}


//TODO https://socket.dev/npm/package/prisma-extension-cuid2

model Transport {
  id     Int           @id @default(autoincrement())
  cuid   String        @unique @default(cuid())
  app    String
  name   String
  type   TransportType
  config Json          @db.JsonB()
  stats  Json?         @db.JsonB()

  validationContent ValidationContent @default(TEXT)
  validationAddress ValidationAddress @default(ANY)

  Sessions   Session[]
  Broadcasts Broadcast[]
  Templates  Template[]
  Pricing    TransportPricing?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  updatedBy String    @default("system")
  deletedAt DateTime?

  @@map("tbl_transports")
}

model TransportPricing {
  id            Int           @id @default(autoincrement())
  cuid          String        @unique @default(cuid())
  transportCuid String        @unique
  transport     Transport     @relation(fields: [transportCuid], references: [cuid], onDelete: Cascade)
  creditPerUnit Decimal       @db.Decimal(10, 6)
  unitType      CreditUnitType
  currency      String        @default("USD")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("tbl_transport_pricing")
}

model Template {
  id          Int      @id @default(autoincrement())
  cuid        String   @unique @default(cuid())
  app         String
  transportId String
  name        String
  externalId  String?  
  status      TemplateStatus
  type        TemplateType
  isActive    Boolean  @default(true)
  language    String   @default("en")
  body        String?
  media       String[]
  xref        String?
  info        String?  //update info or rejection reason from provider
  lastApprovalCheck DateTime? //timestamp of last approval check with provider

  Transport   Transport @relation(fields: [transportId], references: [cuid])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt()

  @@map("tbl_templates")
}


model Session {
  id             Int           @id @default(autoincrement())
  cuid           String        @unique @default(cuid())
  app            String
  transport      String
  message        Json          @db.JsonB()
  addresses      Json          @db.JsonB()
  maxAttempts    Int           @default(1)
  triggerType    TriggerType   @default(IMMEDIATE)
  webhook        String?
  options        Json?         @db.JsonB()
  status         SessionStatus @default(NEW)
  totalAddresses Int
  stats          Json?         @db.JsonB()
  xref           String?

  Transport  Transport      @relation(fields: [transport], references: [cuid])
  Broadcasts Broadcast[]
  Logs       BroadcastLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()
  updatedBy String    @default("system")
  deletedAt DateTime?

  @@map("tbl_sessions")
}

model Broadcast {
  id          Int             @id @default(autoincrement())
  cuid        String          @unique @default(cuid())
  app         String
  session     String
  transport   String
  address     String
  status      BroadcastStatus @default(SCHEDULED)
  maxAttempts Int             @default(1)
  disposition Json?           @db.JsonB()
  attempts    Int             @default(0)
  isComplete  Boolean         @default(false)
  lastAttempt DateTime?
  xref        String?

  Session   Session   @relation(fields: [session], references: [cuid])
  Transport Transport @relation(fields: [transport], references: [cuid])

  Logs BroadcastLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()

  @@map("tbl_broadcasts")
}

model BroadcastLog {
  id        Int             @id @default(autoincrement())
  cuid      String          @unique @default(cuid())
  app       String
  session   String
  broadcast String
  status    BroadcastStatus @default(PENDING)
  attempt   Int
  details   Json?           @db.JsonB()
  notes     String?

  Broadcast Broadcast @relation(fields: [broadcast], references: [cuid])
  Session   Session   @relation(fields: [session], references: [cuid])

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt()

  @@map("tbl_broadcast_logs")
}

// ++++++++++++++++++ START: @rumsan/extensions/apps +++++++++++++++++++++++++++
enum ApplicationEnvironment {
  PRODUCTION
  STAGING
  DEVELOPMENT
  TEST
}

model Application {
  cuid        String                 @id @default(cuid())
  name        String
  publicKey   String
  description String?
  environment ApplicationEnvironment

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  updatedBy String    @default("system")
  deletedAt DateTime?

  @@map("tbl_applications")
}

model UsageSnapshot {
  id              Int           @id @default(autoincrement())
  cuid            String        @unique @default(cuid())
  app             String
  xref            String    @default("")
  transportCuid   String
  transportType   TransportType
  date            DateTime      @db.Date

  sessionCount    Int           @default(0)
  broadcastCount  Int           @default(0)
  successCount    Int           @default(0)
  failCount       Int           @default(0)

  totalCharacters Int           @default(0)
  totalSegments   Int           @default(0)

  totalDurationSec Int          @default(0)
  totalCalls      Int           @default(0)

  creditsUsed     Decimal       @default(0) @db.Decimal(14, 6)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([app, xref, transportCuid, date])
  @@index([app, date])
  @@index([app, xref, date])
  @@map("tbl_usage_snapshots")
}

// ++++++++++++++++++ END: @rumsan/extensions/apps ++++++++++++++++++++++++++++++++
