# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/connect"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AMQP Configuration
AMQP_URL=amqp://localhost:5672

# Scheduling Configuration
# Scheduler type: 'bull' (default) or 'redis_zset'
# 'bull' uses Bull's built-in delay mechanism
# 'redis_zset' uses Redis sorted sets for more efficient scheduling
BROADCAST_SCHEDULER=bull

# Time window (in hours) for scheduling messages
# Messages scheduled beyond this window will be queued by ScheduledWindowWorker
# when they enter the window (default: 48 hours)
BROADCAST_SCHEDULE_WINDOW_HOURS=48

# Batch size for processing scheduled messages (default: 50)
BROADCAST_SCHEDULER_BATCH_SIZE=50

# Redis keys for ZSET scheduler (only used when BROADCAST_SCHEDULER=redis_zset)
BROADCAST_SCHEDULER_ZSET_KEY=connect:broadcast:schedule:zset
BROADCAST_SCHEDULER_PAYLOAD_KEY=connect:broadcast:schedule:payload
BROADCAST_SCHEDULER_PROCESSING_KEY=connect:broadcast:schedule:processing

# Application Configuration
PORT=3000
NODE_ENV=development
